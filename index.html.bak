{type:'progress',icon:'📋',agent:'DUE DILIGENCE',msg:'Background check in progress: NovaTech founding team (3/4 clear) 🔍'},
{type:'completed',icon:'⚙️',agent:'PORTFOLIO OPS',msg:'Board deck generated: Meridian Q4 — actually looks good this time 📊'},
{type:'fun',icon:'🎵',agent:'MARKET INTEL',msg:'vibing to lo-fi beats while analyzing Fed minutes — it\'s a vibe 🎶'},
{type:'completed',icon:'⭐',agent:'CELEBRITY MATCH',msg:'Brand synergy score: 87/100 for Athlete Fund partnership 🏆'},
{type:'alert',icon:'⚙️',agent:'PORTFOLIO OPS',msg:'⚠️ Meridian burn rate 22% over projection — scheduling intervention'},
{type:'completed',icon:'🔍',agent:'DEAL SCOUT',msg:'Climate tech scan: 3 companies meet thesis — mother nature approved 🌍'},
{type:'progress',icon:'🤝',agent:'LP RELATIONS',msg:'Drafting Q1 investor letter — making numbers sound sexy 📝'},
{type:'completed',icon:'📊',agent:'MARKET INTEL',msg:'Fed sentiment: 78% probability of rate hold — dovish energy 🕊️'},
{type:'fun',icon:'🎮',agent:'RISK ENGINE',msg:'ran a stress test on my stress levels — results: stressed 😅'},
{type:'completed',icon:'📋',agent:'DUE DILIGENCE',msg:'TAM validation: SaaS infra market $48B by 2028 — big if true 📈'},
{type:'progress',icon:'🚪',agent:'EXIT STRATEGY',msg:'Secondary market analysis: evaluating 3 buyers — bidding war incoming 🥊'},
{type:'completed',icon:'⭐',agent:'CELEBRITY MATCH',msg:'Media impact model: $2.1M equiv value — we\'re basically famous 💅'},
{type:'alert',icon:'📊',agent:'MARKET INTEL',msg:'🚨 Competitor alert: Nova Capital raising $500M Fund V — noted.'},
{type:'fun',icon:'🍕',agent:'DEAL SCOUT',msg:'pizza break — you can\'t scout deals on an empty stomach 🍕'},
{type:'completed',icon:'🤝',agent:'LP RELATIONS',msg:'KYC complete: New family office LP ($15M) — welcome aboard! 🎊'},
{type:'progress',icon:'🛡️',agent:'RISK ENGINE',msg:'Running liquidity forecast — calculating how long we can party 🎉'},
{type:'completed',icon:'📋',agent:'DUE DILIGENCE',msg:'Financial model validated: NovaTech projections are conservative — rare W 🏆'},
{type:'info',icon:'🚪',agent:'EXIT STRATEGY',msg:'Lock-up tracker: 2 positions unlocking in 30 days — freedom incoming 🗽'},
{type:'deal-closed',icon:'⭐',agent:'CELEBRITY MATCH',msg:'🎊 NEW LP SIGNED: High-profile athlete, $10M commitment — HUGE W'},
{type:'alert',icon:'🔍',agent:'DEAL SCOUT',msg:'🔥 HOT DEAL: Quantum Computing, $5M seed, ex-Google founders — need this NOW'},
{type:'completed',icon:'📊',agent:'MARKET INTEL',msg:'Weekly digest published: 12 key movements — your bedtime reading 📖'},
{type:'fun',icon:'🤖',agent:'CELEBRITY MATCH',msg:'teaching the algorithm about memes — it\'s learning fast 🧠'},
{type:'completed',icon:'⚙️',agent:'PORTFOLIO OPS',msg:'All 67 portfolio company dashboards refreshed — I am speed ⚡'},
];

const funds=[
{name:'Fund I',aum:'$180M',deployed:'98%',irr:34.2,tvpi:'3.1x',status:'Harvesting'},
{name:'Fund II',aum:'$320M',deployed:'92%',irr:28.7,tvpi:'2.6x',status:'Harvesting'},
{name:'Fund III',aum:'$450M',deployed:'78%',irr:31.1,tvpi:'2.2x',status:'Deploying'},
{name:'Fund IV',aum:'$520M',deployed:'45%',irr:22.3,tvpi:'1.5x',status:'Deploying'},
{name:'Fund V',aum:'$380M',deployed:'12%',irr:18.9,tvpi:'1.1x',status:'Deploying'},
{name:'Opp I',aum:'$200M',deployed:'88%',irr:41.5,tvpi:'3.8x',status:'Harvesting'},
{name:'Growth',aum:'$250M',deployed:'65%',irr:12.4,tvpi:'1.3x',status:'Full Invest'},
{name:'Climate',aum:'$100M',deployed:'30%',irr:15.8,tvpi:'1.2x',status:'Deploying'}
];
const pipelineData=[
{label:'Sourced',count:124,color:'rgba(0,255,200,0.15)'},
{label:'Screen',count:45,color:'rgba(0,255,200,0.3)'},
{label:'DD',count:12,color:'rgba(0,255,200,0.45)'},
{label:'IC',count:5,color:'rgba(0,255,200,0.6)'},
{label:'Term',count:3,color:'rgba(0,255,200,0.8)'},
{label:'Closed',count:1,color:'var(--accent)'}
];
const sectors=[
{name:'AI/ML',pct:34,color:'linear-gradient(90deg,#00ffc8,#00e676)'},
{name:'Fintech',pct:18,color:'linear-gradient(90deg,#7b61ff,#a78bfa)'},
{name:'Health',pct:15,color:'linear-gradient(90deg,#00e676,#4ecdc4)'},
{name:'Climate',pct:12,color:'linear-gradient(90deg,#ffb800,#ff8c00)'},
{name:'Space',pct:8,color:'linear-gradient(90deg,#ff4757,#ff6b81)'},
{name:'Consumer',pct:7,color:'linear-gradient(90deg,#4ecdc4,#44bba4)'},
{name:'Enterprise',pct:6,color:'linear-gradient(90deg,#888,#aaa)'}
];
const metricsData=[
{label:'Total AUM',value:'$2.4B',spark:true},
{label:'Active Deals',value:'23',spark:true},
{label:'Portfolio Cos',value:'67'},
{label:'Avg IRR',value:'28.4%',green:true},
{label:'Closed (MTD)',value:'4'},
{label:'LP Pipeline',value:'$340M'},
{label:'Exits (YTD)',value:'3'},
{label:'Tasks Today',value:'0',counter:true}
];

// ── CLOCK ──
function updateClock(){
const now=new Date();
document.getElementById('clock-time').textContent=now.toLocaleTimeString('en-US',{hour12:false});
document.getElementById('clock-date').textContent=now.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'});
}
setInterval(updateClock,1000);updateClock();

// ── MARKET MOOD ──
const moods=['😎','😎','😎','😏','🤔','😐','😰','😎','😏','😎'];
let moodIdx=0;
const moodEl=document.getElementById('market-mood');
setInterval(()=>{moodIdx=(moodIdx+1)%moods.length;moodEl.textContent=moods[moodIdx];moodEl.style.transform='scale(1.3)';
setTimeout(()=>moodEl.style.transform='scale(1)',300)},8000);

// ── METRICS ──
const metricsEl=document.getElementById('metrics');
metricsData.forEach((m,i)=>{
const card=document.createElement('div');card.className='metric-card';
let spark='';
if(m.spark){spark='<div class="sparkline">';for(let j=0;j<12;j++){spark+=`<div class="bar" style="height:${Math.random()*16+4}px"></div>`}spark+='</div>'}
card.innerHTML=`<div class="label">${m.label}</div><div class="value${m.green?' green':''}" id="metric-${i}">${m.value}</div>${spark}`;
metricsEl.appendChild(card);
});

// ── TASK COUNTER ──
let taskCount=247;
const taskEl=document.getElementById('total-tasks');
const metricTaskEl=document.getElementById('metric-7');
function updateTasks(){
taskCount++;
taskEl.textContent=taskCount;metricTaskEl.textContent=taskCount;
metricTaskEl.classList.remove('bounce');void metricTaskEl.offsetWidth;metricTaskEl.classList.add('bounce');
}
setInterval(updateTasks,4500);taskEl.textContent=taskCount;metricTaskEl.textContent=taskCount;

// ── AGENTS ──
const agentsEl=document.getElementById('agents');
const agentTaskIdx=agents.map(()=>0);
const statusColors={green:'var(--success)',amber:'var(--warn)',blue:'var(--purple)'};
agents.forEach((a,i)=>{
const div=document.createElement('div');div.className='agent-item';div.id=`agent-${i}`;
const cpuC=a.cpu>80?'var(--danger)':a.cpu>60?'var(--warn)':'var(--accent)';
const memC=a.mem>80?'var(--danger)':a.mem>60?'var(--warn)':'var(--accent)';
div.innerHTML=`<div class="agent-header">
<span class="agent-avatar" id="avatar-${i}" style="animation-delay:${i*0.4}s">${a.icon}<span class="agent-mood" id="mood-${i}">${a.mood}</span></span>
<span class="name">${a.name}</span>
<span class="status-dot" style="background:${statusColors[a.status]};box-shadow:0 0 8px ${statusColors[a.status]}"></span></div>
<div class="agent-task" id="atask-${i}">${a.tasks[0]}</div>
<div class="agent-meta"><span class="count" id="acount-${i}">${a.completed} done</span>
<div class="progress-bar"><div class="fill" style="width:${a.progress}%"></div></div>
<span style="font-size:8px">${new Date().toLocaleTimeString('en-US',{hour12:false}).slice(0,5)}</span></div>
<div class="usage-bars">
<div class="usage-bar"><div class="lbl">CPU</div><div class="track"><div class="fill" id="cpu-${i}" style="width:${a.cpu}%;background:${cpuC}"></div></div></div>
<div class="usage-bar"><div class="lbl">MEM</div><div class="track"><div class="fill" id="mem-${i}" style="width:${a.mem}%;background:${memC}"></div></div></div>
</div>
<div class="agent-bio" id="bio-${i}">
<div class="bio-name">${a.bio.name}</div>
<div>${a.bio.title}</div>
<div class="bio-trait">"${a.bio.trait}"</div>
<div style="margin-top:4px">${a.bio.backstory}</div>
</div>`;
div.addEventListener('click',()=>{
const bio=document.getElementById(`bio-${i}`);
document.querySelectorAll('.agent-bio.show').forEach(b=>{if(b!==bio)b.classList.remove('show')});
bio.classList.toggle('show');
});
agentsEl.appendChild(div);
});

// Rotate tasks + jitter usage + mood animations
setInterval(()=>{
agents.forEach((a,i)=>{
agentTaskIdx[i]=(agentTaskIdx[i]+1)%a.tasks.length;
const el=document.getElementById(`atask-${i}`);
el.style.opacity='0';
setTimeout(()=>{el.textContent=a.tasks[agentTaskIdx[i]];el.style.opacity='1'},300);

// Random mood changes
const avatar=document.getElementById(`avatar-${i}`);
const moodSpan=document.getElementById(`mood-${i}`);
if(Math.random()>.6){
const isExcited=Math.random()>.5;
moodSpan.textContent=isExcited?a.moodExcited:a.mood;
if(i===0&&isExcited)avatar.className='agent-avatar excited'; // Deal Scout
else if(i===5&&isExcited)avatar.className='agent-avatar nervous'; // Risk Engine
else if(i===7&&isExcited)avatar.className='agent-avatar dance'; // Celebrity Match
else avatar.className='agent-avatar';
}else{
moodSpan.textContent=a.mood;avatar.className='agent-avatar';
}

// Completed count bump
if(Math.random()>.7){a.completed++;document.getElementById(`acount-${i}`).textContent=a.completed+' done'}

// CPU/MEM jitter
const nc=Math.min(99,Math.max(10,a.cpu+Math.round((Math.random()-.5)*16)));
const nm=Math.min(99,Math.max(10,a.mem+Math.round((Math.random()-.5)*10)));
a.cpu=nc;a.mem=nm;
document.getElementById(`cpu-${i}`).style.cssText=`width:${nc}%;background:${nc>80?'var(--danger)':nc>60?'var(--warn)':'var(--accent)'}`;
document.getElementById(`mem-${i}`).style.cssText=`width:${nm}%;background:${nm>80?'var(--danger)':nm>60?'var(--warn)':'var(--accent)'}`;
});
},4000);

// ── CONFETTI ──
function fireConfetti(){
const colors=['#00ffc8','#7b61ff','#ffb800','#ff4757','#00e676','#ff69b4','#4ecdc4'];
for(let i=0;i<40;i++){
const piece=document.createElement('div');piece.className='confetti-piece';
piece.style.left=Math.random()*100+'vw';
piece.style.top='-10px';
piece.style.background=colors[Math.floor(Math.random()*colors.length)];
piece.style.borderRadius=Math.random()>.5?'50%':'2px';
piece.style.width=Math.random()*6+4+'px';
piece.style.height=Math.random()*6+4+'px';
piece.style.animationDuration=Math.random()*1.5+1.5+'s';
piece.style.animationDelay=Math.random()*.5+'s';
document.body.appendChild(piece);
setTimeout(()=>piece.remove(),4000);
}
}

// ── FEED ──
const feedList=document.getElementById('feed-list');
let feedIdx=0;
function addFeedEntry(){
const m=feedMessages[feedIdx%feedMessages.length];feedIdx++;
const ts=new Date().toLocaleTimeString('en-US',{hour12:false});
const e=document.createElement('div');e.className=`feed-entry ${m.type}`;
e.innerHTML=`<span class="ts">${ts}</span> ${m.icon} <span class="agent">${m.agent}</span> — ${m.msg}`;
feedList.insertBefore(e,feedList.firstChild);
if(feedList.children.length>25)feedList.removeChild(feedList.lastChild);
if(m.type==='deal-closed')fireConfetti();
}
for(let i=0;i<8;i++)addFeedEntry();
setInterval(addFeedEntry,2500);

// ── FUND TABLE ──
document.getElementById('fund-table').innerHTML='<tr><th>Fund</th><th>AUM</th><th>Depl</th><th>IRR</th><th>TVPI</th><th>Status</th></tr>'+
funds.map(f=>`<tr><td style="color:var(--accent)">${f.name}</td><td>${f.aum}</td><td>${f.deployed}</td><td class="${f.irr>25?'irr-high':f.irr>15?'irr-mid':'irr-low'}">${f.irr}%</td><td>${f.tvpi}</td><td style="color:var(--dim)">${f.status}</td></tr>`).join('');

// ── PIPELINE ──
document.getElementById('pipeline').innerHTML='<div class="pipeline">'+pipelineData.map(p=>
`<div class="pipe-stage" style="flex:${Math.max(p.count/124,.08)};background:${p.color};min-width:48px"><span class="count">${p.count}</span><span class="lbl">${p.label}</span></div>`).join('')+'</div>';

// ── SECTORS ──
const secEl=document.getElementById('sectors');
sectors.forEach(s=>{secEl.innerHTML+=`<div class="sector-bar"><span class="name">${s.name}</span><div class="track"><div class="fill" style="width:${s.pct}%;background:${s.color}">${s.pct}%</div></div></div>`});

// ── SPARKLINE ANIM ──
setInterval(()=>{document.querySelectorAll('.sparkline').forEach(sl=>{sl.querySelectorAll('.bar').forEach(b=>{b.style.height=Math.random()*16+4+'px'})})},3000);
</script>
</body>
</html>
