<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SANBO OS — Command Center</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#0a0e1a;--card:rgba(15,20,35,0.85);--border:rgba(0,255,200,0.15);
--accent:#00ffc8;--purple:#7b61ff;--warn:#ffb800;--danger:#ff4757;--success:#00e676;
--text:#e0e0e0;--dim:#888;--font-mono:'JetBrains Mono',monospace;--font-sans:system-ui,-apple-system,sans-serif;
--glow:rgba(0,255,200,0.08);
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font-mono);overflow-x:hidden}

/* Scanlines */
body::after{content:'';position:fixed;top:0;left:0;width:100%;height:100%;
background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.02) 2px,rgba(0,0,0,0.02) 4px);
pointer-events:none;z-index:9999}

/* Particles canvas */
#particles{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:.6}

/* Gradient mesh bg */
body::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;
background:radial-gradient(ellipse at 20% 50%,rgba(123,97,255,0.06) 0%,transparent 50%),
radial-gradient(ellipse at 80% 20%,rgba(0,255,200,0.05) 0%,transparent 40%),
radial-gradient(ellipse at 60% 80%,rgba(255,71,87,0.04) 0%,transparent 40%);
pointer-events:none;z-index:0}

.panel{background:var(--card);border:1px solid var(--border);border-radius:8px;position:relative;overflow:hidden;
backdrop-filter:blur(8px);z-index:1}
.panel::before,.panel::after{content:'';position:absolute;width:14px;height:14px;border-color:var(--accent);border-style:solid;opacity:.3;z-index:2}
.panel::before{top:0;left:0;border-width:2px 0 0 2px;border-radius:8px 0 0 0}
.panel::after{bottom:0;right:0;border-width:0 2px 2px 0;border-radius:0 0 8px 0}
.panel-title{font-size:10px;font-weight:600;letter-spacing:2px;color:var(--accent);text-transform:uppercase;padding:12px 14px 6px;font-family:var(--font-sans)}

/* TOP BAR */
#topbar{position:fixed;top:0;left:0;right:0;height:52px;
background:linear-gradient(135deg,rgba(8,12,24,0.97),rgba(15,10,30,0.97));
border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;
padding:0 20px;z-index:100;backdrop-filter:blur(12px)}
#topbar .logo{display:flex;align-items:center;gap:10px}
#topbar .logo h1{font-size:18px;font-weight:700;
background:linear-gradient(135deg,var(--accent),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;
letter-spacing:3px}
#topbar .logo span{font-size:9px;color:var(--dim);letter-spacing:2px;text-transform:uppercase}
#topbar .clock{font-size:20px;font-weight:300;color:var(--text);letter-spacing:1px;text-align:center}
#topbar .clock .date{font-size:10px;color:var(--dim)}
#topbar .status{display:flex;align-items:center;gap:16px;font-size:11px}
.dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:4px;animation:pulse 2s ease-in-out infinite}
.dot.green{background:var(--success);box-shadow:0 0 8px var(--success)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

#market-mood{font-size:20px;cursor:pointer;transition:transform .3s;display:inline-block}
#market-mood:hover{transform:scale(1.3)}

/* MAIN */
#app{padding-top:52px;display:flex;flex-direction:column;min-height:100vh;position:relative;z-index:1}

/* METRICS */
#metrics{display:grid;grid-template-columns:repeat(8,1fr);gap:8px;padding:10px 12px}
.metric-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:12px;text-align:center;
position:relative;overflow:hidden;cursor:default;transition:transform .2s,border-color .3s}
.metric-card:hover{transform:translateY(-2px);border-color:rgba(0,255,200,0.35)}
.metric-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;
background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:0;transition:opacity .3s}
.metric-card:hover::after{opacity:1}
.metric-card .label{font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:1px;font-family:var(--font-sans)}
.metric-card .value{font-size:22px;font-weight:700;margin:4px 0 2px;color:var(--text);transition:transform .3s}
.metric-card .value.green{color:var(--success)}
.metric-card .sparkline{height:20px;display:flex;align-items:flex-end;justify-content:center;gap:1px;margin-top:2px}
.metric-card .sparkline .bar{width:3px;background:linear-gradient(to top,var(--accent),var(--purple));opacity:.6;border-radius:1px;transition:height .5s cubic-bezier(.34,1.56,.64,1)}

/* Counter bounce */
@keyframes countBounce{0%{transform:scale(1)}50%{transform:scale(1.15)}100%{transform:scale(1)}}
.bounce{animation:countBounce .4s cubic-bezier(.34,1.56,.64,1)}

/* MAIN GRID */
#main{display:grid;grid-template-columns:30% 40% 30%;gap:8px;padding:0 12px 8px;flex:1;min-height:0;overflow:hidden}

/* AGENTS */
#agents{overflow-y:auto;padding:8px;max-height:calc(100vh - 210px)}
#agents::-webkit-scrollbar{width:4px}
#agents::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.agent-item{padding:10px;border-bottom:1px solid rgba(255,255,255,0.04);transition:all .25s;cursor:pointer;border-radius:6px;margin-bottom:2px}
.agent-item:hover{background:rgba(0,255,200,0.04);border-color:transparent}
.agent-header{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.agent-avatar{font-size:22px;display:inline-block;animation:float 3s ease-in-out infinite;position:relative}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
.agent-avatar.excited{animation:excited .5s ease-in-out infinite}
@keyframes excited{0%,100%{transform:scale(1) rotate(0)}25%{transform:scale(1.1) rotate(-5deg)}75%{transform:scale(1.1) rotate(5deg)}}
.agent-avatar.nervous{animation:nervous .3s ease-in-out infinite}
@keyframes nervous{0%,100%{transform:translateX(0)}25%{transform:translateX(-2px)}75%{transform:translateX(2px)}}
.agent-avatar.dance{animation:dance .6s ease-in-out infinite}
@keyframes dance{0%,100%{transform:translateY(0) rotate(0)}25%{transform:translateY(-4px) rotate(-8deg)}50%{transform:translateY(0) rotate(0)}75%{transform:translateY(-4px) rotate(8deg)}}
.agent-mood{font-size:12px;position:absolute;top:-4px;right:-8px}
.agent-header .name{font-size:11px;font-weight:600;color:var(--text);text-transform:uppercase;letter-spacing:1px}
.agent-header .status-dot{width:7px;height:7px;border-radius:50%;margin-left:auto;animation:pulse 2s ease-in-out infinite}
.agent-task{font-size:10px;color:var(--accent);opacity:.85;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:5px;transition:opacity .3s}
.agent-meta{display:flex;gap:8px;font-size:9px;color:var(--dim);align-items:center}
.agent-meta .count{color:var(--accent);font-weight:600}
.progress-bar{flex:1;height:3px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden}
.progress-bar .fill{height:100%;border-radius:2px;transition:width 1s;background:linear-gradient(90deg,var(--accent),var(--purple))}
.usage-bars{display:flex;gap:6px;margin-top:5px}
.usage-bar{flex:1}
.usage-bar .lbl{font-size:8px;color:var(--dim);margin-bottom:1px}
.usage-bar .track{height:3px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden}
.usage-bar .fill{height:100%;border-radius:2px;transition:width 2s}

/* Agent bio popup */
.agent-bio{display:none;background:linear-gradient(135deg,rgba(20,25,45,0.98),rgba(30,20,50,0.98));
border:1px solid var(--border);border-radius:10px;padding:14px;margin-top:8px;font-size:10px;line-height:1.5;
color:var(--dim);animation:popIn .3s cubic-bezier(.34,1.56,.64,1)}
.agent-bio.show{display:block}
.agent-bio .bio-name{color:var(--accent);font-weight:700;font-size:12px;margin-bottom:4px}
.agent-bio .bio-trait{color:var(--purple);font-style:italic}
@keyframes popIn{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}

/* FEED */
#feed{overflow:hidden;position:relative;max-height:calc(100vh - 210px)}
#feed-list{padding:8px;display:flex;flex-direction:column;gap:3px}
.feed-entry{font-size:10px;padding:7px 10px;border-radius:6px;background:rgba(255,255,255,0.02);
animation:slideIn .4s cubic-bezier(.34,1.56,.64,1);line-height:1.5;border-left:3px solid transparent;
transition:background .2s}
.feed-entry:hover{background:rgba(255,255,255,0.04)}
.feed-entry.completed{border-left-color:var(--success)}
.feed-entry.progress{border-left-color:var(--warn)}
.feed-entry.info{border-left-color:var(--purple)}
.feed-entry.alert{border-left-color:var(--danger)}
.feed-entry.fun{border-left-color:#ff69b4}
.feed-entry.deal-closed{border-left-color:var(--success);background:rgba(0,230,118,0.06)}
.feed-entry .ts{color:var(--dim);margin-right:4px}
.feed-entry .agent{font-weight:600;color:var(--accent)}
@keyframes slideIn{from{opacity:0;transform:translateY(-12px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}

/* Confetti */
.confetti-piece{position:fixed;width:8px;height:8px;z-index:10000;pointer-events:none;animation:confettiFall 2.5s cubic-bezier(.25,.46,.45,.94) forwards}
@keyframes confettiFall{0%{opacity:1;transform:translateY(0) rotate(0) scale(1)}100%{opacity:0;transform:translateY(100vh) rotate(720deg) scale(.3)}}

/* RIGHT */
#dashboards{overflow-y:auto;padding:0;display:flex;flex-direction:column;gap:8px;max-height:calc(100vh - 210px)}
#dashboards::-webkit-scrollbar{width:4px}
#dashboards::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.fund-table{width:100%;border-collapse:collapse;font-size:9px}
.fund-table th{text-align:left;padding:5px 6px;color:var(--dim);font-weight:400;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:1px}
.fund-table td{padding:5px 6px;border-bottom:1px solid rgba(255,255,255,0.03);transition:background .2s}
.fund-table tr:hover td{background:rgba(0,255,200,0.03)}
.irr-high{color:var(--success);font-weight:600}.irr-mid{color:var(--warn)}.irr-low{color:var(--danger)}

.pipeline{display:flex;align-items:center;gap:2px;margin:8px 0}
.pipe-stage{text-align:center;padding:10px 4px;font-size:9px;border-radius:6px;color:#fff;transition:transform .2s;cursor:default}
.pipe-stage:hover{transform:scale(1.05)}
.pipe-stage .count{font-size:18px;font-weight:700;display:block}
.pipe-stage .lbl{font-size:8px;opacity:.8;text-transform:uppercase;letter-spacing:.5px}

.sector-bar{display:flex;align-items:center;gap:8px;margin:5px 0;font-size:10px}
.sector-bar .name{width:70px;text-align:right;color:var(--dim);font-size:9px}
.sector-bar .track{flex:1;height:16px;background:rgba(255,255,255,0.03);border-radius:4px;overflow:hidden}
.sector-bar .fill{height:100%;border-radius:4px;display:flex;align-items:center;padding-left:6px;font-size:8px;font-weight:600;color:#fff;transition:width 1.2s cubic-bezier(.34,1.56,.64,1)}

/* TICKER */
#ticker{height:30px;background:linear-gradient(90deg,rgba(8,12,24,0.95),rgba(15,10,30,0.95));
border-top:1px solid var(--border);overflow:hidden;display:flex;align-items:center;z-index:1}
#ticker .scroll{white-space:nowrap;animation:marquee 35s linear infinite;font-size:11px;color:var(--dim)}
#ticker .scroll span{color:var(--accent)}
#ticker .scroll .hot{color:var(--danger)}
@keyframes marquee{0%{transform:translateX(100vw)}100%{transform:translateX(-100%)}}

/* Mobile */
@media(max-width:900px){
#metrics{grid-template-columns:repeat(4,1fr)}
#main{grid-template-columns:1fr;grid-template-rows:auto auto auto}
#topbar .status{display:none}
}
@media(max-width:500px){#metrics{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>
<canvas id="particles"></canvas>

<div id="topbar">
  <div class="logo"><h1>✦ SANBO OS</h1><span>Command Center</span></div>
  <div class="clock"><div id="clock-time">--:--:--</div><div class="date" id="clock-date">---</div></div>
  <div class="status">
    <span><span class="dot green"></span>8 AGENTS ONLINE</span>
    <span id="market-mood" title="Mood of the Market">😎</span>
    <span>HEALTH <span style="color:var(--success)">99.7%</span></span>
    <span>TASKS <span id="total-tasks" style="color:var(--accent);font-weight:700">0</span></span>
  </div>
</div>

<div id="app">
  <div id="metrics"></div>
  <div id="main">
    <div class="panel" id="agent-panel"><div class="panel-title">👾 Agent Status Board</div><div id="agents"></div></div>
    <div class="panel" id="feed-panel"><div class="panel-title">⚡ Live Activity Feed</div><div id="feed"><div id="feed-list"></div></div></div>
    <div id="dashboards">
      <div class="panel"><div class="panel-title">💰 Fund Performance</div><div style="padding:0 10px 10px"><table class="fund-table" id="fund-table"></table></div></div>
      <div class="panel"><div class="panel-title">🔮 Deal Pipeline</div><div style="padding:0 10px 10px" id="pipeline"></div></div>
      <div class="panel"><div class="panel-title">🎯 Sector Allocation</div><div style="padding:0 10px 10px" id="sectors"></div></div>
    </div>
  </div>
  <div id="ticker">
    <div class="scroll">
      🚀 AUM <span>$2.4B</span> ▲ 12% QoQ &nbsp;•&nbsp; Deals Closed: <span>4</span> this month &nbsp;•&nbsp; IRR <span>28.4%</span> (Fund Avg) &nbsp;•&nbsp; Portfolio Revenue: <span>$890M</span> combined &nbsp;•&nbsp; 🔥 3 IPO candidates in pipeline &nbsp;•&nbsp; Next LP meeting: <span>Mar 18</span> &nbsp;•&nbsp; <span class="hot">VIBES: IMMACULATE</span> &nbsp;•&nbsp;
      🚀 AUM <span>$2.4B</span> ▲ 12% QoQ &nbsp;•&nbsp; Deals Closed: <span>4</span> this month &nbsp;•&nbsp; IRR <span>28.4%</span> (Fund Avg) &nbsp;•&nbsp; Portfolio Revenue: <span>$890M</span> combined &nbsp;•&nbsp; 🔥 3 IPO candidates in pipeline &nbsp;•&nbsp; Next LP meeting: <span>Mar 18</span> &nbsp;•&nbsp; <span class="hot">VIBES: IMMACULATE</span>
    </div>
  </div>
</div>

<script>
// ── PARTICLES ──
const cvs=document.getElementById('particles'),ctx=cvs.getContext('2d');
function resizeCvs(){cvs.width=window.innerWidth;cvs.height=window.innerHeight}
resizeCvs();window.addEventListener('resize',resizeCvs);
const sparkles=[];
for(let i=0;i<40;i++)sparkles.push({x:Math.random()*cvs.width,y:Math.random()*cvs.height,
r:Math.random()*1.5+.5,dx:(Math.random()-.5)*.3,dy:(Math.random()-.5)*.3,
a:Math.random(),da:Math.random()*.01+.005,
color:Math.random()>.5?'0,255,200':'123,97,255'});
function drawParticles(){
ctx.clearRect(0,0,cvs.width,cvs.height);
sparkles.forEach(s=>{
s.x+=s.dx;s.y+=s.dy;s.a+=s.da;
if(s.x<0)s.x=cvs.width;if(s.x>cvs.width)s.x=0;
if(s.y<0)s.y=cvs.height;if(s.y>cvs.height)s.y=0;
const alpha=Math.abs(Math.sin(s.a))*.5+.1;
ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
ctx.fillStyle=`rgba(${s.color},${alpha})`;ctx.fill();
// glow
ctx.beginPath();ctx.arc(s.x,s.y,s.r*3,0,Math.PI*2);
ctx.fillStyle=`rgba(${s.color},${alpha*.15})`;ctx.fill();
});
requestAnimationFrame(drawParticles);
}
drawParticles();

// ── DATA ──
const agents=[
{icon:'🔍',name:'DEAL SCOUT',status:'green',mood:'😏',moodExcited:'🤩',animClass:'',
bio:{name:'Scout McSearchface',title:'Chief Deal Sniffer',trait:'Gets unreasonably excited about TAMs over $10B',backstory:'Born in a spreadsheet, raised by AngelList. Once found a unicorn in a coffee shop pitch deck. Favorite food: term sheets.'},
tasks:["Oh snap, this one's a 🦄 — Series A, $50M TAM, 400% growth","AngelList: 847 new listings processed... my scroll finger hurts 💪","PitchBook alert: 3 Series A in climate 🌍 let's goooo","Crunchbase deep dive: 450 founders, 12 look spicy 🌶️"],completed:47,cpu:72,mem:58,progress:78},
{icon:'📋',name:'DUE DILIGENCE',status:'amber',mood:'🧐',moodExcited:'😤',animClass:'',
bio:{name:'Diligence Dan',title:'Professional Skeptic',trait:'Has trust issues (professionally)',backstory:'Trained by reading 10,000 pitch decks. Can smell inflated metrics from 3 cap tables away. Still has nightmares about WeWork.'},
tasks:["NovaTech: revenue $12M, growing 340% YoY — okay I'm impressed 👀","Cap table is clean af — no red flags 🟢","Reference checks: 5/6 complete... last one's ghosting me 👻","TAM validation: $48B confirmed. Math checks out ✅"],completed:31,cpu:89,mem:74,progress:92},
{icon:'🤝',name:'LP RELATIONS',status:'green',mood:'😊',moodExcited:'🥰',animClass:'',
bio:{name:'Relations Rachel',title:'Vibes Manager',trait:'Can turn a cold email into a warm hug',backstory:'Speaks fluent LP. Knows every family office birthday. Once got a $50M commitment over afternoon tea. Professional schmoozer.'},
tasks:["Q4 report distributed to 23 LPs — they're gonna love this 💅","Capital call notice: $12M Series B — money printer goes brrrr 🖨️","LP portal: 45 views today, someone's doing their homework 📚","New LP onboarded: KYC verified, welcome to the fam! 🎉"],completed:22,cpu:34,mem:41,progress:45},
{icon:'📊',name:'MARKET INTEL',status:'green',mood:'🤓',moodExcited:'🚨',animClass:'',
bio:{name:'Intel McBrainiac',title:'Data Whisperer',trait:'Reads the Fed minutes for fun on weekends',backstory:'Has a Bloomberg Terminal tattooed on their heart. Once predicted a market crash by analyzing pizza delivery patterns. Unironically calls charts "beautiful."'},
tasks:["AI multiples: 2.1x (down from 3.8x) — the correction is real 📉","Fed decision in 48hrs — dovish vibes, I can feel it 🕊️","Competitor alert: Nova raising $500M — respectfully, we're not worried 💅","Sector rotation: health → climate — follow the money 🌊"],completed:56,cpu:61,mem:53,progress:67},
{icon:'⚙️',name:'PORTFOLIO OPS',status:'amber',mood:'😤',moodExcited:'💪',animClass:'',
bio:{name:'Ops Olivia',title:'Herder of Cats',trait:'Has 47 browser tabs open and knows exactly what each one is for',backstory:'Manages 67 portfolio companies and somehow remembers all their KPIs. Runs on coffee and dashboards. Their calendar is a war zone.'},
tasks:["Meridian: burn rate 22% over projection — we need to talk 😬","Board decks generated for 4 companies — my magnum opus 🎨","Monthly KPIs refreshed — 12 updates, zero complaints 🏆","Hiring tracker: 34 open roles — everyone's hiring, nobody's applying 🤷"],completed:38,cpu:77,mem:82,progress:85},
{icon:'🛡️',name:'RISK ENGINE',status:'green',mood:'😰',moodExcited:'😱',animClass:'',
bio:{name:'Risk-O-Matic 3000',title:'Professional Worrier',trait:'Sees danger everywhere. Probably right.',backstory:'Runs 10,000 simulations before breakfast. Has a "worst case scenario" for every worst case scenario. Sleeps with a volatility chart under their pillow.'},
tasks:["Monte Carlo: 95th %ile TVPI 3.2x — *nervous sweating* 😅","Concentration: 34% AI (limit: 40%) — cutting it close fam ⚠️","Stress test: recession = -18% NAV — I don't feel so good 🤢","Liquidity forecast: 14 months runway — we're fine... probably 🤞"],completed:29,cpu:95,mem:67,progress:71},
{icon:'🚪',name:'EXIT STRATEGY',status:'blue',mood:'😎',moodExcited:'🤑',animClass:'',
bio:{name:'Exit Eddie',title:'Door Opener Extraordinaire',trait:'Knows every M&A banker on a first name basis',backstory:'Has an exit for every entry. Once negotiated a 12x return at a dinner party. Their LinkedIn is just a list of successful exits.'},
tasks:["IPO window: 3 fintech cos eligible — ring that bell! 🔔","Secondary bid: $45M for 8% stake — interesting... 🤔","M&A comps: 8.2x revenue multiple — chef's kiss 🤌","Lock-up expiry: 2 positions in 30 days — almost free! 🗽"],completed:14,cpu:28,mem:35,progress:32},
{icon:'⭐',name:'CELEBRITY MATCH',status:'green',mood:'💃',moodExcited:'🎉',animClass:'',
bio:{name:'Star Power Sally',title:'Celebrity Whisperer',trait:'Has every A-lister\'s manager on speed dial',backstory:'Built the algorithm that matches celebrities to investment theses. Once got a rapper to invest in enterprise SaaS. Their rolodex is legendary.'},
tasks:["LP prospect: 94% thesis alignment — it's a match! 💘","Brand synergy analysis complete — the vibes are immaculate ✨","3 warm intros queued — sliding into DMs professionally 📩","Media impact model: $2.1M equiv value — we're famous 📸"],completed:19,cpu:45,mem:39,progress:52}
];

const feedMessages=[
{type:'completed',icon:'🔍',agent:'DEAL SCOUT',msg:'Match found: AeroVolt (Series A, $8M, Clean Energy) → Forwarded to DD 🎯'},
{type:'completed',icon:'🛡️',agent:'RISK ENGINE',msg:'Stress test complete: Base case TVPI 2.8x, Bear case 1.9x — we survive 💪'},
{type:'alert',icon:'📊',agent:'MARKET INTEL',msg:'🚨 ALERT: Stripe IPO filing detected — impact analysis started'},
{type:'completed',icon:'⚙️',agent:'PORTFOLIO OPS',msg:'KPI update: TechFlow revenue hit $5M MRR milestone 🎉🎉🎉'},
{type:'completed',icon:'🤝',agent:'LP RELATIONS',msg:'Capital call email sent to 23 LPs ($12M Series B co-invest) 💸'},
{type:'alert',icon:'📋',agent:'DUE DILIGENCE',msg:'🚩 Red flag: CloudMesh customer concentration 68% — yikes'},
{type:'deal-closed',icon:'🚪',agent:'EXIT STRATEGY',msg:'🎊 DEAL CLOSED: Acquisition of PortfolioCo at 12x revenue — LFG!!!'},
{type:'info',icon:'⭐',agent:'CELEBRITY MATCH',msg:'New LP scored: Jamie Chen — 94% alignment, $25M capacity ⭐'},
{type:'progress',icon:'🔍',agent:'DEAL SCOUT',msg:'Processing batch: 234 startups from AngelList — my eyes 👀'},
{type:'completed',icon:'📊',agent:'MARKET INTEL',msg:'Sector report: AI/ML valuations down 22% from peak — buying opportunity? 🤔'},
